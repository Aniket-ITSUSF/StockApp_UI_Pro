# ── Required for production deployment ───────────────────────────────────────
# Set this in your deployment platform (Netlify / Cloudflare Pages / Railway).
# Vite bakes this into the JS bundle at build time - must start with VITE_.
VITE_API_URL=https://web-production-3648f.up.railway.app/api

# ── Local development ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values for local dev.
# .env.local is gitignored and never committed.
# VITE_API_URL=http://localhost:8000/api
